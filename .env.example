# ─── MercadoPago ─────────────────────────────────────────────────────────────
# Get credentials at: mercadopago.com.ar → Panel → Credenciales
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000
MP_WEBHOOK_SECRET=your-webhook-hmac-secret

# ─── Resend (email) ───────────────────────────────────────────────────────────
